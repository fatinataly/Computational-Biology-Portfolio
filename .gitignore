# -------------------------------------------------
# 📓 Jupyter Notebooks
# -------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints/
*.nbconvert.ipynb

# -------------------------------------------------
# 🐍 Python bytecode & cache
# -------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd

# -------------------------------------------------
# 🧪 Virtual environments
# -------------------------------------------------
venv/
env/
.env/
.env.*

# -------------------------------------------------
# 🧬 Bioinformatics data artifacts
# -------------------------------------------------
*.sam
*.bam
*.bai
*.fastq
*.fq
*.fasta
*.fa
*.vcf
*.bcf
*.bed
*.gff
*.gtf

# -------------------------------------------------
# 🔬 Nextflow
# -------------------------------------------------
.nextflow
.nextflow.log*
work/
results/


# -------------------------------------------------
# 🧪 Temporary / pipeline outputs
# -------------------------------------------------
*.tmp
*.temp
*.log

# -------------------------------------------------
# 💻 System files
# -------------------------------------------------
.DS_Store
Thumbs.db

# -------------------------------------------------
# 🧑‍💻 IDEs
# -------------------------------------------------
.vscode/
.idea/

# -------------------------------------------------
# 🔐 Secrets (never commit genomic keys 👀)
# -------------------------------------------------
*.key
*.pem
secrets.*
credentials.*

